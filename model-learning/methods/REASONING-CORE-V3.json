{
  "schema": "FORTUNE-REASONING-CORE-V3",
  "method_id": "REASONING-CORE-V3",
  "contains_case_answer_mapping": false,
  "modifies_canonical_source_files": false,
  "purpose": "Generalization-first reasoning procedure shared by Chat and Work; new cases provide first-blind evidence, while spaced replays diagnose remediation without masquerading as independent evidence.",
  "stages": [
    {
      "stage": "INPUT_FREEZE",
      "required_outputs": ["calendar_and_chart_coordinates", "question_and_option_atoms", "data_quality_status"],
      "stop_conditions": ["answer_visibility", "unrecoverable_question_or_option_damage", "unresolved_critical_chart_field"]
    },
    {
      "stage": "BLIND_FACT_MODEL",
      "required_outputs": ["subject_entities", "topic_axes", "reference_periods", "real_world_endpoints"],
      "rule": "Build before option ranking and do not treat an option assertion as a known fact."
    },
    {
      "stage": "ZIWEI_INDEPENDENT_TRACK",
      "required_outputs": ["natal_structure", "star_system_and_palace_expression", "transformation_chain", "time_activation_when_needed", "capability_limits"],
      "rule": "Static tendency, dynamic activation and completed event are separate levels."
    },
    {
      "stage": "BAZI_INDEPENDENT_TRACK",
      "required_outputs": ["seasonal_strength_and_flow", "structure_axes", "structural_changes", "luck_cycle_activation_when_needed", "topic_capability_limits"],
      "rule": "Do not copy Ziwei mechanisms or jump from ten gods, useful-god, clash, fu-yin or shensha to an exact endpoint."
    },
    {
      "stage": "REALITY_CLOSURE",
      "required_outputs": ["actor", "action", "object", "time", "result", "missing_endpoint_atoms", "alternative_explanations"],
      "rule": "Risk and opportunity remain distinct from occurrence and formal completion."
    },
    {
      "stage": "PAIRWISE_SELECTION",
      "required_outputs": ["all_option_pairs", "temporary_first", "strongest_rival", "reversal_test", "top1", "top2", "confidence"],
      "rule": "Shared atoms and duplicate physical evidence do not decide a pair."
    },
    {
      "stage": "FREEZE_THEN_REVEAL",
      "required_outputs": ["immutable_prediction", "prediction_hash", "bound_source_and_model_versions"],
      "rule": "No scoring or answer access before a complete freeze."
    },
    {
      "stage": "ROUND_FEEDBACK_AND_GENERALIZATION_GATE",
      "required_outputs": ["round_score", "independent_case_pass_streak", "generic_learning_if_failed", "next_new_case_or_spaced_replay"],
      "rule": "Each distinct new case contributes at most one first-blind result. A failed first blind resets the cross-case streak, requires generic learning, and queues the case for replay after at least five newer cases. Replays diagnose remediation but never count toward the three-case gate."
    }
  ],
  "evidence_priority": [
    "direct_same_axis_counterevidence",
    "completed_actor_time_endpoint_chain",
    "time-bound_distinguishing_mechanism",
    "stable_topic-specific_structure",
    "general_scene_or_tendency",
    "low-weight_auxiliary_marker"
  ],
  "non_accumulation_rules": [
    "same_physical_fact_counts_once",
    "source_count_is_not_weight",
    "school_count_is_not_weight",
    "three_evidence_items_are_a_minimum_summary_not_a_maximum_ledger",
    "ziwei_and_bazi_agreement_without_independent_parentage_adds_no_gain"
  ],
  "uncertainty_rules": [
    "lower confidence when exact actor, endpoint or time is missing",
    "label forced relative choice when all options exceed source capability",
    "sensitive, rare, non-falsifiable and high-severity claims cannot use a single marker or singleton rule",
    "input damage blocks the affected case before prediction"
  ],
  "post_reveal_error_classes": [
    "INPUT_RECOGNITION",
    "QUESTION_ROUTING",
    "SUBJECT_TAIJI",
    "NATAL_STRUCTURE",
    "TIME_ACTIVATION",
    "REALITY_SEMANTICS",
    "REGION_ERA_SCALE",
    "ZIWEI_BAZI_ARBITRATION",
    "COMPOSITE_ATOMIZATION",
    "STRONGEST_RIVAL_COMPARISON",
    "EXECUTION_OMISSION",
    "UNCERTAINTY_CALIBRATION"
  ],
  "learning_boundary": {
    "failed_round_must_activate_generic_model_learning": true,
    "passing_round_must_not_create_answer_derived_rule": true,
    "same_case_replay_is_independent_evidence": false,
    "unrelated_question_is_rule_evidence": false,
    "required_consecutive_independent_passes": 3,
    "minimum_new_cases_between_replays": 5,
    "failed_first_blind_resets_independent_passes": true,
    "same_case_replay_counts_toward_stage_gate": false
  }
}
