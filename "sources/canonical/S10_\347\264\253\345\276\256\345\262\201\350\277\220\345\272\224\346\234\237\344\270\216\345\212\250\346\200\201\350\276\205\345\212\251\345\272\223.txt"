{"source_root_atom_id":"HL-A-1665","source_sequence":1665,"primary_authority_library":"S10","source_line_start":7525,"source_line_end":7529,"blank_lines_after":1,"parent_volume":"卷四十八·紫微斗数·终极理则与大限流年应验全篇","parent_section":"四、命主、身主与宫位阴阳","parent_subsection":"","raw_text":"   命主：北七星。吉位为夫妻、官禄、财帛、福德、田宅、父母。\n   身主：南七星。吉位为兄弟、交友、命宫、迁移、子女、疾厄。\n   命主辅助命宫，身主辅助身宫，用以断荣枯。入命迁表多劳，入疾厄表\n   身体不好。\n   生年干为戊，属阳，命主也是阳星，此时命宫最好也落在阳宫为佳。","raw_text_sha256":"174c86321ff672ecbaa9c001e907d5c5abca1e07171776ece0328a00ef56c404","clause_ids":["HL-C-1665-01","HL-C-1665-02","HL-C-1665-03","HL-C-1665-04","HL-C-1665-05","HL-C-1665-06","HL-C-1665-07","HL-C-1665-08"],"relation_ids":["HL-R-1665-01","HL-R-1665-02","HL-R-1665-03"],"relation_closure_status":"PASS","logical_operators":["NEGATION","QUANTITY"],"palace_tags":["命宫"],"star_tags":[],"transformation_tags":["禄"],"temporal_tags":[],"topic_tags":["CAREER_WORK","FINANCE_CASHFLOW","MARRIAGE_RELATION","CHILDREN_FERTILITY","HEALTH_RISK","PROPERTY_HOME","MIGRATION_OUTSIDE","PARTNERSHIP_NETWORK","PARENT_FAMILY"],"technique_ids":["HL_HEALTH"],"result_term_candidates":[],"risk_tags":[],"contribution_mode":"CONDITIONAL_SOURCE_CANDIDATE","s17_required":true,"s18_review_required":false,"s02_translation_required":false}
