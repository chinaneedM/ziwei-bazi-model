{"source_root_atom_id":"HL-A-1690","source_sequence":1690,"primary_authority_library":"S10","source_line_start":7642,"source_line_end":7645,"blank_lines_after":1,"parent_volume":"卷四十八·紫微斗数·终极理则与大限流年应验全篇","parent_section":"十、各类杂断集成","parent_subsection":"","raw_text":"(十) 阴阳和合\n   三合方有禄忌，而无权科：是为独阳不生，孤阴不长。阴阳要和合，始谓\n   之有情。\n   权忌：表麻烦多，因权为暗斗，虽可解忌，但麻烦不免。若逢科则可解。","raw_text_sha256":"05bc21229f85e07995e8fe154244b00973b70e01fb3374c113327b0e8f2fbbd2","clause_ids":["HL-C-1690-01","HL-C-1690-02","HL-C-1690-03","HL-C-1690-04","HL-C-1690-05","HL-C-1690-06"],"relation_ids":["HL-R-1690-01","HL-R-1690-02","HL-R-1690-03","HL-R-1690-04","HL-R-1690-05","HL-R-1690-06"],"relation_closure_status":"PASS","logical_operators":["CONDITION","NEGATION","CONTRAST","QUANTITY"],"palace_tags":[],"star_tags":[],"transformation_tags":["禄","权","科","忌"],"temporal_tags":[],"topic_tags":[],"technique_ids":[],"result_term_candidates":[],"risk_tags":[],"contribution_mode":"CONDITIONAL_SOURCE_CANDIDATE","s17_required":false,"s18_review_required":false,"s02_translation_required":false}
