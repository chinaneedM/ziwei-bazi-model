__pycache__/
*.py[cod]
.venv/
build/
dist/
*.egg-info/

# Plaintext answers and keys are never repository data.
*.answer-key
*.answers.json
*.decrypted-answer.json

# Only encrypted answer envelopes may be committed here.
answer-vault/encrypted/*
!answer-vault/encrypted/.gitkeep
!answer-vault/encrypted/*.json.fernet
