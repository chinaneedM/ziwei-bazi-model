{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://answer-vault/answer-object-v1",
  "title": "FORTUNE_ANSWER_OBJECT_V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "authorized_run_id", "answers"],
  "properties": {
    "schema": {"const": "FORTUNE-ANSWER-OBJECT-V1"},
    "authorized_run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "answers": {"type": "string", "minLength": 1}
  }
}
