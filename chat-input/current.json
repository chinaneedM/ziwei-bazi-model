        "COMPOSITE_ATOMIZATION",
        "STRONGEST_RIVAL_COMPARISON",
        "EXECUTION_OMISSION",
        "UNCERTAINTY_CALIBRATION"
      ],
      "purpose": "Stable question-level reasoning procedure shared by Chat and Work; case-derived rules remain separate and evidence-tracked.",
      "schema": "FORTUNE-REASONING-CORE-V3",
      "stages": [
        {
          "required_outputs": [
            "calendar_and_chart_coordinates",
            "question_and_option_atoms",
            "data_quality_status"
          ],
          "stage": "INPUT_FREEZE",
          "stop_conditions": [
            "answer_visibility",
            "unrecoverable_question_or_option_damage",
            "unresolved_critical_chart_field"
          ]
        },
        {
          "required_outputs": [
            "subject_entities",
            "topic_axes",
            "reference_periods",
            "real_world_endpoints"
          ],
          "rule": "Build before option ranking and do not treat an option assertion as a known fact.",
          "stage": "BLIND_FACT_MODEL"
        },
        {
          "required_outputs": [
            "natal_structure",
            "star_system_and_palace_expression",
            "transformation_chain",
            "time_activation_when_needed",
            "capability_limits"
          ],
          "rule": "Static tendency, dynamic activation and completed event are separate levels.",
          "stage": "ZIWEI_INDEPENDENT_TRACK"
        },
        {
          "required_outputs": [
            "seasonal_strength_and_flow",
            "structure_axes",
            "structural_changes",
            "luck_cycle_activation_when_needed",
            "topic_capability_limits"
          ],
          "rule": "Do not copy Ziwei mechanisms or jump from ten gods, useful-god, clash, fu-yin or shensha to an exact endpoint.",
          "stage": "BAZI_INDEPENDENT_TRACK"
        },
        {
          "required_outputs": [
            "actor",
            "action",
            "object",
            "time",
            "result",
            "missing_endpoint_atoms",
            "alternative_explanations"
          ],
          "rule": "Risk and opportunity remain distinct from occurrence and formal completion.",
          "stage": "REALITY_CLOSURE"
        },
        {
          "required_outputs": [
            "all_option_pairs",
            "temporary_first",
            "strongest_rival",
            "reversal_test",
            "top1",
            "top2",
            "confidence"
          ],
          "rule": "Shared atoms and duplicate physical evidence do not decide a pair.",
          "stage": "PAIRWISE_SELECTION"
        },
        {
          "required_outputs": [
            "immutable_prediction",
            "prediction_hash",
            "bound_source_and_model_versions"
          ],
          "rule": "No scoring or answer access before a complete freeze.",
          "stage": "FREEZE_THEN_REVEAL"
        }
      ],
      "uncertainty_rules": [
        "lower confidence when exact actor, endpoint or time is missing",
        "label forced relative choice when all options exceed source capability",
        "sensitive, rare, non-falsifiable and high-severity claims cannot use a single marker or singleton rule",
        "input damage blocks the affected case before prediction"
      ]
    },
    "release_id": "MODEL-LEARNING-002",
    "rule_application_policy": {
      "CANDIDATE": "Use only when scope matches; never as sole evidence.",
      "CHALLENGED": "Treat as a warning or counter-hypothesis, not a decisive rule.",
      "PROVISIONAL": "Use as a low-weight hypothesis and never as sole evidence.",
      "VALIDATED": "May be used normally within its declared scope."
    }
