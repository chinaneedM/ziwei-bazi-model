    "active_rules": [
      {
        "applicability": "候选竞争广义职业类别与更窄的具体岗位、场所或身份时。",
        "capability_ceiling": "只有能力、桃花、才艺或公众性证据时，最高释放到广义职业族。",
        "counterexamples": "完整组合在同一有效结构中出现，且阶段、谋生动作、场所和收入链同时闭合时，较窄职业可以胜出。",
        "decision_procedure": "逐项检查雇佣或经营主体、日常动作、行业场所、服务对象、收入形式、进入年龄和持续性，并惩罚缺失的独有节点。",
        "limits": "单一组合或分散星曜只能建立条件性职业候选，不能拼接成不存在的完整岗位链。",
        "reasoning_skill_tags": [
          "TOPIC_PALACE_ROUTING",
          "OPTION_GRANULARITY",
          "EVIDENCE_WEIGHTING",
          "CAREER_PROFILE_CLOSURE"
