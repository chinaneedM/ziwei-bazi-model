{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://schemas/prompt-snapshot-v1",
  "title": "MAIN_PROMPT_AUDIT_SNAPSHOT",
  "type": "object",
  "required": ["schema", "runtime_id", "snapshot_sha256", "snapshot_bytes", "captured_at", "authority_statement", "expected", "actual", "checks", "status"],
  "properties": {
    "schema": {"const": "MAIN-PROMPT-AUDIT-SNAPSHOT-V1"}, "runtime_id": {"type": "string"},
    "snapshot_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "captured_at": {"type": "string"},
    "authority_statement": {"const": "AUDIT_COPY_ONLY_NOT_RUNTIME_AUTHORITY"},
    "runtime_attestation": {"type": ["object", "null"]},
    "expected": {"type": "object"}, "actual": {"type": "object"},
    "checks": {"type": "object"}, "status": {"enum": ["PASS", "PROMPT_EXPORT_MISMATCH"]}
  }
}
