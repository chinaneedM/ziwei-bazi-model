{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://schemas/prediction-run-v1",
  "title": "PREDICTION_RUN",
  "type": "object",
  "required": ["schema", "run_id", "case_id", "dataset_type", "binding", "input_snapshot", "questions", "runtime_validation"],
  "properties": {
    "schema": {"const": "PREDICTION-RUN-V1"},
    "run_id": {"type": "string"},
    "case_id": {"type": "string"},
    "dataset_type": {"enum": ["DEV", "REGRESSION", "FROZEN_EVAL"]},
    "binding": {
      "type": "object",
      "required": ["library_binding_hash", "main_prompt_runtime_id", "code_commit", "schema_version"],
      "properties": {
        "library_binding_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "main_prompt_runtime_id": {"type": "string"},
        "prompt_snapshot_sha256": {"type": ["string", "null"]},
        "code_commit": {"type": "string"},
        "schema_version": {"type": "string"}
      }
    },
    "input_snapshot": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
    },
    "questions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question_id", "option_ids", "top1", "top2", "confidence", "blind_core", "public_evidence", "strongest_competitor_reason", "most_important_unverified_atom", "ziwei_track", "bazi_track", "fusion", "coverage_plan", "evidence_ledger", "direction_matrix", "compound_coverage", "pairwise_rows", "formal_exact_assertion"],
        "properties": {
          "question_id": {"type": "string"},
          "option_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
          "top1": {"type": "string"}, "top2": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "blind_core": {"type": "string", "minLength": 1},
          "public_evidence": {"type": "array", "minItems": 3, "maxItems": 5, "items": {"type": "object"}},
          "strongest_competitor_reason": {"type": "string"},
          "most_important_unverified_atom": {"type": "string"},
          "ziwei_track": {"type": "object"}, "bazi_track": {"type": "object"}, "fusion": {"type": "object"},
          "coverage_plan": {"type": "object"}, "evidence_ledger": {"type": "array"},
          "direction_matrix": {"type": "object"}, "pairwise_rows": {"type": "array"}
          ,"compound_coverage": {"type": "object"}, "formal_exact_assertion": {"type": ["object", "null"]}
        }
      }
    },
    "runtime_validation": {"type": "object", "required": ["status", "checks"]}
  }
}
