{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chinaneedM/ziwei-bazi-model/schemas/training-evidence-manifest.schema.json",
  "title": "Group training evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "group_id",
    "group_run_id",
    "training_unit_count",
    "units",
    "object_hash"
  ],
  "properties": {
    "schema": {"const": "GROUP-TRAINING-EVIDENCE-MANIFEST-V1"},
    "status": {"const": "READY_FOR_SERIAL_EVALUATION"},
    "group_id": {"type": "string", "minLength": 1},
    "group_run_id": {"type": "string", "minLength": 1},
    "training_unit_count": {"type": "integer", "minimum": 1},
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit_id", "evidence_path", "evidence_sha256", "evidence_object_hash"],
        "properties": {
          "unit_id": {"type": "string", "minLength": 1},
          "evidence_path": {"type": "string", "minLength": 1},
          "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "evidence_object_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "object_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
