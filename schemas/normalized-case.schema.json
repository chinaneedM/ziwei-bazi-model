{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://schemas/normalized-case-v1",
  "title": "NORMALIZED_CASE",
  "type": "object",
  "required": ["schema", "case_id", "dataset_type", "package_sha256", "files", "status"],
  "properties": {
    "schema": {"const": "NORMALIZED-CASE-V1"},
    "case_id": {"type": "string", "minLength": 1},
    "dataset_type": {"enum": ["DEV", "REGRESSION", "FROZEN_EVAL"]},
    "package_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["logical_type", "original_name", "sha256", "bytes", "storage_domain"],
        "properties": {
          "logical_type": {"enum": ["ZIWEI_TEXT", "BAZI_IMAGE", "QUESTIONS", "ANSWER", "NOTE"]},
          "original_name": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0},
          "storage_domain": {"enum": ["RUNTIME", "ANSWER_VAULT"]}
        },
        "additionalProperties": false
      }
    },
    "status": {"enum": ["NORMALIZED", "INPUT_QUARANTINE"]},
    "conflicts": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}

