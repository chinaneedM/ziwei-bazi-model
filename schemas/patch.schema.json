{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://schemas/patch-v1",
  "title": "PATCH_CANDIDATE",
  "type": "object",
  "required": ["schema", "patch_id", "layer", "defect_class", "universal_parent_chain", "changes", "leak_scan"],
  "properties": {
    "schema": {"const": "PATCH-CANDIDATE-V1"}, "patch_id": {"type": "string"},
    "layer": {"enum": ["INTERFACE", "RETRIEVAL", "SEMANTIC", "ENTITY", "TIME", "ENDPOINT", "INDEPENDENCE", "FUSION", "MAPPING", "RELEASE"]},
    "defect_class": {"type": "string"}, "universal_parent_chain": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "changes": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "leak_scan": {"type": "object", "required": ["status", "findings"]}
  }
}

