{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://schemas/knowledge-index-v1",
  "title": "DERIVED_KNOWLEDGE_LOCATOR_INDEX",
  "type": "object",
  "required": ["schema", "binding_hash", "sources", "entries"],
  "properties": {
    "schema": {"const": "KNOWLEDGE-LOCATOR-INDEX-V1"},
    "binding_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "sources": {"type": "array"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["library_id", "source_sha256", "root_atom", "parent_segment", "line_start", "line_end", "byte_start", "byte_end", "conditions", "negations", "limitations", "exceptions", "alternatives"],
        "properties": {
          "library_id": {"pattern": "^S(0[1-9]|1[0-8])$"}, "source_sha256": {"pattern": "^[0-9a-f]{64}$"},
          "root_atom": {"type": "string"},
          "parent_segment": {
            "type": "object",
            "required": ["sha256", "locator"],
            "properties": {"sha256": {"pattern": "^[0-9a-f]{64}$"}, "locator": {"const": "EXACT_SOURCE_BYTE_RANGE"}}
          },
          "line_start": {"type": "integer", "minimum": 1}, "line_end": {"type": "integer", "minimum": 1},
          "byte_start": {"type": "integer", "minimum": 0}, "byte_end": {"type": "integer", "minimum": 0},
          "conditions": {"type": "array"}, "negations": {"type": "array"}, "limitations": {"type": "array"},
          "exceptions": {"type": "array"}, "alternatives": {"type": "array"}
        }
      }
    }
  }
}
