{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune://schemas/bazi-transcription-v1",
  "title": "BAZI_FROZEN_TRANSCRIPTION",
  "type": "object",
  "required": ["schema", "case_id", "object_id", "image_sha256", "method", "method_version", "versions", "frozen_at"],
  "properties": {
    "schema": {"const": "BAZI-FROZEN-TRANSCRIPTION-V1"},
    "case_id": {"type": "string"},
    "object_id": {"type": "string"},
    "image_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "method": {"type": "string"},
    "method_version": {"type": "string"},
    "versions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["version_id", "fields", "status"],
        "properties": {
          "version_id": {"type": "string"},
          "status": {"enum": ["VALID", "PARALLEL_CANDIDATE", "INPUT_QUARANTINE"]},
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["value", "state"],
              "properties": {
                "value": {},
                "state": {"enum": ["VERIFIED", "READABLE_UNCONFIRMED", "AMBIGUOUS", "MISSING", "CONFLICT"]},
                "source_region": {"type": ["string", "null"]},
                "note": {"type": ["string", "null"]}
              }
            }
          }
        }
      }
    },
    "frozen_at": {"type": "string"}
  }
}

