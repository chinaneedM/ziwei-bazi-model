{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fortune-research-hypothesis.schema.json",
  "title": "Fortune Research Hypothesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "hypothesis_id",
    "statement",
    "domain_and_track",
    "origin",
    "source_parent_atoms",
    "mechanism",
    "applicability_conditions",
    "limitations",
    "counterexamples",
    "capability_ceiling",
    "alternative_explanations",
    "supporting_case_ids",
    "contradicting_case_ids",
    "same_set_clean_metrics",
    "unseen_metrics",
    "provenance_independence",
    "status",
    "promotion_target"
  ],
  "properties": {
    "hypothesis_id": {"type": "string", "pattern": "^HYP-[A-Z0-9-]+$"},
    "statement": {"type": "string", "minLength": 20},
    "domain_and_track": {
      "type": "object",
      "required": ["domain", "track"],
      "properties": {
        "domain": {"enum": ["ZIWEI", "BAZI", "CROSS_TRACK", "REALITY_ENDPOINT", "RETRIEVAL", "ADJUDICATION", "INPUT", "TIME"]},
        "track": {"enum": ["KNOWLEDGE", "PROGRAM", "BOTH"]}
      },
      "additionalProperties": false
    },
    "origin": {
      "type": "object",
      "required": ["round_id", "origin_type", "created_at"],
      "properties": {
        "round_id": {"type": "string"},
        "origin_type": {"enum": ["POSTREVEAL_REVIEW", "SOURCE_SYNTHESIS", "CROSS_CASE_PATTERN", "USER_EXPERT_INPUT", "OPEN_RESEARCH"]},
        "created_at": {"type": "string", "format": "date-time"},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    },
    "source_parent_atoms": {"type": "array", "items": {"type": "object"}},
    "mechanism": {"type": "string", "minLength": 20},
    "applicability_conditions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "limitations": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "counterexamples": {"type": "array", "items": {"type": "string"}},
    "capability_ceiling": {"type": "string", "minLength": 10},
    "alternative_explanations": {"type": "array", "items": {"type": "string"}},
    "supporting_case_ids": {"type": "array", "items": {"type": "string"}},
    "contradicting_case_ids": {"type": "array", "items": {"type": "string"}},
    "same_set_clean_metrics": {
      "type": "object",
      "required": ["attempts", "support_hits", "contradictions", "status"],
      "properties": {
        "attempts": {"type": "integer", "minimum": 0},
        "support_hits": {"type": "integer", "minimum": 0},
        "contradictions": {"type": "integer", "minimum": 0},
        "status": {"enum": ["NOT_RUN", "INCONCLUSIVE", "SUPPORTED", "CONTRADICTED"]}
      },
      "additionalProperties": false
    },
    "unseen_metrics": {
      "type": "object",
      "required": ["cases", "support_hits", "contradictions", "status"],
      "properties": {
        "cases": {"type": "integer", "minimum": 0},
        "support_hits": {"type": "integer", "minimum": 0},
        "contradictions": {"type": "integer", "minimum": 0},
        "status": {"enum": ["NOT_RUN", "INCONCLUSIVE", "SUPPORTED", "CONTRADICTED"]}
      },
      "additionalProperties": false
    },
    "provenance_independence": {
      "type": "object",
      "required": ["independent_case_count", "same_source_family_count", "status"],
      "properties": {
        "independent_case_count": {"type": "integer", "minimum": 0},
        "same_source_family_count": {"type": "integer", "minimum": 0},
        "status": {"enum": ["NOT_ESTABLISHED", "PARTIAL", "PASS", "FAIL"]}
      },
      "additionalProperties": false
    },
    "status": {"enum": ["PROPOSED", "SPECIFIED", "RETROSPECTIVE_SUPPORT_ONLY", "SAME_SET_CLEAN_SUPPORT", "UNSEEN_VALIDATION_ACTIVE", "VALIDATED_CANDIDATE", "PROMOTED_TO_ACTIVE_SOURCE", "REJECTED", "SUPERSEDED"]},
    "promotion_target": {"type": ["string", "null"]},
    "decision_log": {"type": "array", "items": {"type": "object"}}
  }
}